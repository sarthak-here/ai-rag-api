# ── AI Provider — set to "anthropic" (default) or "ollama" ────────────────────
AI_PROVIDER=anthropic

# ── Anthropic (required when AI_PROVIDER=anthropic) ───────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_NAME="RAG Document Intelligence API"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db

# ── Vector Store ──────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=documents

# ── Model ─────────────────────────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── Ollama (required when AI_PROVIDER=ollama) ──────────────────────────────────
# Make sure Ollama is running: https://ollama.com
# Pull a model first: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── RAG Tuning ────────────────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=5
